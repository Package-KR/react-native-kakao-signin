{
  "name": "@packagekr/kakao-login",
  "version": "0.0.1",
  "description": "React Native Kakao Login",
  "main": "src/index",
  "types": "src/index.d.ts",
  "scripts": {
    "android:dev": "npm run android:dev --workspace KakaoLoginExample",
    "android:prod": "npm run android:prod --workspace KakaoLoginExample",
    "ios:dev": "npm run ios:dev --workspace KakaoLoginExample --",
    "ios:prod": "npm run ios:prod --workspace KakaoLoginExample --",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start --workspace KakaoLoginExample",
    "test": "npm run test --workspaces --if-present"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Package-KR/RNSocialLogin"
  },
  "files": [
    "src",
    "ios",
    "android",
    "*.podspec",
    "!KakaoLoginExample",
    "!android/build",
    "!ios/build"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "kakao",
    "login"
  ],
  "license": "MIT",
  "workspaces": [
    "KakaoLoginExample"
  ],
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "codegenConfig": {
    "name": "RNKakaoLoginSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.packagekr.kakao"
    }
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
